pnpm run typecheck
pnpm vitest run

# DB-backed listing-vs-detail parity sweep over every real investment. Loads .env so it
# actually runs (the plain vitest run above skips it for lack of DB env), and fails the
# push if the local DB is unreachable — a skipped parity check is false confidence.
pnpm test:parity

echo "Dumping production DB from Neon..."
if pnpm db:dump && [ -s dumps/dump-latest.sql ]; then
  echo "✅ DB dump succeeded ($(du -h dumps/dump-latest.sql | cut -f1))"
else
  echo "❌ DB dump failed or produced empty file"
  exit 1
fi

echo "Pruning dumps older than 7 days..."
pruned=$(find dumps -name 'dump-*.sql' ! -name 'dump-latest.sql' -mtime +7 -print -delete 2>/dev/null | wc -l | tr -d ' ')
echo "✅ Pruned ${pruned:-0} old dump(s)"

# Background watcher: prints Vercel deployment state transitions to this terminal.
# Detached subshell so `git push` returns immediately when the hook exits.
# DEPLOY_SHA pins the watcher to THIS commit's deploy (matched by SHA), not "newest".
# Set SKIP_WATCH_DEPLOY=1 to bypass (CI machines, offline pushes, etc.).
#
# Foreground auth precheck FIRST (~1s): a dead local CLI token can't watch
# deploys, and a backgrounded watcher would just poll blind and then misblame the
# Git integration 3 min later. Surface it loudly here instead. Non-fatal — never
# block a push over LOCAL auth; just skip the (useless) watcher.
if [ -z "${SKIP_WATCH_DEPLOY:-}" ]; then
  if bash scripts/watch-deploy.sh --check-auth; then
    ( DEPLOY_SHA="$(git rev-parse HEAD)" bash scripts/watch-deploy.sh & )
  else
    echo "  🔒 vercel: skipping deploy watcher — fix local CLI auth (see above), then push again to tail." >&2
  fi
fi
