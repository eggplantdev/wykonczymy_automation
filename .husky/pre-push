# ── Prod-migration gate (gate + remind only — NEVER touches the DB) ──────────
# Payload migrations no longer run at build time, so a Vercel deploy can't change
# the schema. Schema is now a separate, human-owned plane. On a push to main that
# ADDS a migration under src/migrations/, stop and make the human acknowledge that
# prod must be migrated by hand (`pnpm db:migrate:prod`, backup-first) — schema
# BEFORE the code that needs it goes live. This block only asks; it runs no SQL.
# Reads /dev/tty because git feeds the pushed-ref list to a pre-push hook on stdin.
PROD_BRANCH=main
push_to_prod= sha_from= sha_to=
while read -r _local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/$PROD_BRANCH" ]; then
    push_to_prod=1; sha_from=$remote_sha; sha_to=$local_sha
  fi
done

if [ -n "$push_to_prod" ]; then
  if [ "$sha_from" = "0000000000000000000000000000000000000000" ]; then
    sha_from=$(git hash-object -t tree /dev/null)   # new branch: diff vs empty tree
  fi
  # --diff-filter=A: only ADDED migrations are pending applies. A rename/edit or a
  # deletion (e.g. removing a smoke-test migration) is never something prod needs.
  if git diff --name-only --diff-filter=A "$sha_from" "$sha_to" -- src/migrations/ | grep -q '\.ts$'; then
    if { : < /dev/tty; } 2>/dev/null; then
      printf '\n⚠  Push to %s adds new src/migrations/.\n   Prod is NOT auto-migrated. Run `pnpm db:migrate:prod` yourself (backup-first)\n   BEFORE this deploy serves traffic, else the live app runs against an old schema.\n   Push the code now anyway? [y/N] ' "$PROD_BRANCH" > /dev/tty
      read -r go < /dev/tty || go=n
      case "$go" in
        [Yy]*) echo "→ pushing code; remember to run pnpm db:migrate:prod" >&2 ;;
        *)     echo "✗ aborted — migrate prod first, then push" >&2; exit 1 ;;
      esac
    else
      echo "→ no terminal to confirm; pushing code only (migrate prod manually)" >&2
    fi
  fi
fi

pnpm run typecheck
pnpm vitest run

# DB-backed integration specs (restore/snapshot wipe-and-reinsert, delete guards, leads) against
# the ISOLATED 5435 test DB. The plain `vitest run` above skips every one of them for lack of a DB
# env (they gate on `describe.skipIf(!ENV_READY)`), so without this leg the destructive restore path
# never runs before a push. The script ups db-test, keeps its schema current (re-imports the prod
# dump only when migrations changed), and runs the specs serially. See scripts/test-integration.sh.
pnpm test:integration

# DB-backed listing-vs-detail parity sweep over every real investment, against the SAME isolated
# 5435 test DB (prod-dump content) that test:integration just brought up and kept schema-current —
# not the dev DB. Overrides DB_POSTGRES_URL to the test URL; fails the push if that DB is unreachable
# (a skipped parity check is false confidence).
pnpm test:parity

echo "Dumping production DB from Neon..."
if pnpm db:dump && [ -s dumps/dump-latest.sql ]; then
  echo "✅ DB dump succeeded ($(du -h dumps/dump-latest.sql | cut -f1))"
else
  echo "❌ DB dump failed or produced empty file"
  exit 1
fi

echo "Pruning dumps older than 7 days..."
pruned=$(find dumps -name 'dump-*.sql' ! -name 'dump-latest.sql' -mtime +7 -print -delete 2>/dev/null | wc -l | tr -d ' ')
echo "✅ Pruned ${pruned:-0} old dump(s)"

# Background watcher: prints Vercel deployment state transitions to this terminal.
# Detached subshell so `git push` returns immediately when the hook exits.
# DEPLOY_SHA pins the watcher to THIS commit's deploy (matched by SHA), not "newest".
# Set SKIP_WATCH_DEPLOY=1 to bypass (CI machines, offline pushes, etc.).
#
# Foreground auth precheck FIRST (~1s): a dead local CLI token can't watch
# deploys, and a backgrounded watcher would just poll blind and then misblame the
# Git integration 3 min later. Surface it loudly here instead. Non-fatal — never
# block a push over LOCAL auth; just skip the (useless) watcher.
if [ -z "${SKIP_WATCH_DEPLOY:-}" ]; then
  if bash scripts/watch-deploy.sh --check-auth; then
    ( DEPLOY_SHA="$(git rev-parse HEAD)" bash scripts/watch-deploy.sh & )
  else
    echo "  🔒 vercel: skipping deploy watcher — fix local CLI auth (see above), then push again to tail." >&2
  fi
fi
